{
  "model_path": "${MODEL_ROOT:-/path/to/models}/smollm2-1.7b",
  "tokenizer_path": "${PROJECT_ROOT:-/path/to/project}/tokenizer_assets/mp_fwe100k_en_min2",
  "context_length": 1024,
  "batch_size": 4,
  "learning_rate": 2e-05,
  "dataset": "HuggingFaceTB/smollm-corpus",
  "subset": "fineweb-edu-dedup",
  "split": "train",
  "text_key": "text",
  "shuffle_buffer": 50000,
  "seed": 42,
  "tokens_target": 34000000000,
  "weight_decay": 0.1,
  "warmup_ratio": 0.01,
  "max_grad_norm": 1.0,
  "bf16": true,
  "output_dir": "out/pretrain_scratch/mp/1_7b_mp_fwe100k_en_min2_scratch_34b",
  "save_steps": 200,
  "logging_steps": 10,
  "save_total_limit": 2,
  "resume": "auto",
  "tokenizer_chunk_max": 8192
}
